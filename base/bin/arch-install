#!/bin/sh

# Yet another Arch installer script
# Before writing this, I knew about archfi
# https://github.com/MatMoul/archfi
# archfi is amazing. But it had more options than what I needed.
# I just wanted something that takes as little input as possible
# and only at the beginning and then deals with the installation
# automatically.
# The plan was to make this a general purpose installer but the
# day I wrote it I found out about the official Arch installer
# https://github.com/archlinux/archinstall
# which will probably be superior to other installers soon.
# So, I believe it would be a good idea to keep this installer
# as a minimal installer. Some options might be added later, but
# probably not too much.


[ "$DEV" ]          || DEV=/dev/sdc
[ "$MP" ]           || MP=/mnt/arch-install
[ "$USERNAME" ]     || USERNAME=me
[ "$PASSWORD" ]     || PASSWORD=123
[ "$HOSTNAME" ]     || HOSTNAME=pc
[ "$ZONE" ]         || ZONE=Asia/Qatar
[ "$LOCALES" ]      || LOCALES=en_US.UTF-8:ar_QA.UTF-8
[ "$AUTO_PART" ]    || AUTO_PART=        # tiny, mini, or normal
[ "$LUKS" ]         || LUKS=             # 1 to enable LUKS encryption
[ "$LUKS_PASS" ]    || LUKS_PASS=        # LUKS passphrase (defaults to PASSWORD)
[ "$PROFILE" ]      || PROFILE=minimal
[ "$UNATTENDED" ]   || UNATTENDED=       # 1 to skip all questions

SELF=$(realpath "$0")
NAME=$(basename "$SELF")

C='\033[1m\033[34m' # blue
E='\033[1m\033[31m' # red
R='\033[0m'         # reset

info() {
    printf "${C}INFO:${R} %s\n" "$@"
}

err() {
    printf "${E}ERROR:${R} %s\n" "$@" >&2
}

is_parabola() {
    grep -q 'ID=parabola' /etc/os-release
}

uncomment() {
    line="$1"
    file="$2"
    sed -i "s/# *$line/$line/" "$file"
}

comment() {
    line="$1"
    file="$2"
    sed -i "s/$line/#$line/" "$file"
}

ensure_line() {
    file="$1"
    line="$2"
    grep -qxF "$line" "$file" 2>/dev/null || printf '%s\n' "$line" >> "$file"
}

check_root() {
    if [ "$(id -u)" != 0 ]; then
        echo 'Root is needed'
        exit 1
    fi
}

vars() {
    echo "export DEV=$DEV"
    echo "export MP=$MP"
    echo "export USERNAME=$USERNAME"
    [ "$1" = --all ] && echo "export PASSWORD='$(printf '%s' "$PASSWORD" | sed "s/'/'\\\\''/g")'"
    echo "export HOSTNAME=$HOSTNAME"
    echo "export ZONE=$ZONE"
    echo "export LUKS=$LUKS"
    [ "$1" = --all ] && echo "export LUKS_PASS='$(printf '%s' "${LUKS_PASS:-$PASSWORD}" | sed "s/'/'\\\\''/g")'"
    echo "export PROFILE=$PROFILE"
    echo "export AUTO_PART=$AUTO_PART"
}

is_gpt() {
    gdisk -l "$1" 2>/dev/null | grep -q 'GPT:'
}

convert_gpt_to_mbr() {
    info "Converting GPT to MBR on $DEV..."
    printf 'r\ng\nw\nY\n' | gdisk "$DEV" || return 1
    sleep 2
}

autopart() {
    # Determine layout based on AUTO_PART value
    disk_bytes=$(blockdev --getsize64 "$DEV")
    disk_gb=$((disk_bytes / 1073741824))
    ram_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    ram_gb=$((ram_kb / 1048576))

    case "$AUTO_PART" in
        tiny)
            # No swap, single root partition (no separate boot for BIOS,
            # but we still need a small FAT32 boot for UEFI/GRUB)
            layout="tiny: 256M boot + rest root"
            boot_size=256
            swap_size=0
            ;;
        mini)
            layout="mini: 512M boot + rest root"
            boot_size=512
            swap_size=0
            ;;
        normal|*)
            swap_size=$((ram_gb * 2))
            [ "$swap_size" -lt 1 ] && swap_size=2
            layout="normal: 512M boot + ${swap_size}G swap + rest root"
            boot_size=512
            ;;
    esac

    info "Auto partition layout: $layout (disk=${disk_gb}G, ram=${ram_gb}G)"

    # Wipe and create fresh MBR partition table
    info "Wiping $DEV and creating MBR label..."
    parted -s "$DEV" mklabel msdos || return 1

    start=1 # MiB
    end=$((start + boot_size))

    info "Creating boot partition (${boot_size}MiB)..."
    parted -s "$DEV" mkpart primary fat32 "${start}MiB" "${end}MiB" set 1 boot on || return 1
    start=$end

    if [ "$swap_size" -gt 0 ]; then
        swap_end=$((start + swap_size * 1024))
        info "Creating swap partition (${swap_size}GiB)..."
        parted -s "$DEV" mkpart primary linux-swap "${start}MiB" "${swap_end}MiB" || return 1
        start=$swap_end
    else
        # Create a tiny dummy swap placeholder so DEVP2 exists for the rest
        # of the script — use 1 MiB and simply skip mkswap/swapon later.
        SKIP_SWAP=1
        parted -s "$DEV" mkpart primary linux-swap "${start}MiB" "$((start + 1))MiB" || return 1
        start=$((start + 1))
    fi

    info "Creating root partition (rest of disk)..."
    parted -s "$DEV" mkpart primary ext4 "${start}MiB" 100% || return 1

    sleep 3 # let the kernel re-read the partition table
    partprobe "$DEV" 2>/dev/null || true
}

luks_format() {
    _pass="${LUKS_PASS:-$PASSWORD}"
    _keyfile=$(mktemp)
    printf '%s' "$_pass" > "$_keyfile"
    info "Formatting ${DEVP}3 with LUKS..."
    cryptsetup luksFormat --batch-mode --key-file "$_keyfile" "${DEVP}3" || { rm -f "$_keyfile"; return 1; }
    info "Opening LUKS container as cryptroot..."
    cryptsetup open --key-file "$_keyfile" "${DEVP}3" cryptroot || { rm -f "$_keyfile"; return 1; }
    rm -f "$_keyfile"
}

luks_close() {
    cryptsetup close cryptroot 2>/dev/null || true
}

mkfss() {
    # boot
    info "Formatting ${DEVP}1 as boot partition..."
    if [ -e "${DEVP}1" ]; then
        yes | mkfs.fat -F32 "${DEVP}1"
    else
        err "${DEVP}1 not found"
        return 1
    fi || return 1
    echo

    # swap
    if [ "$SKIP_SWAP" != 1 ]; then
        info "Formatting ${DEVP}2 as swap partition..."
        if [ -e "${DEVP}2" ]; then
            yes | mkswap "${DEVP}2"
        else
            err "${DEVP}2 not found"
            return 1
        fi || return 1
        echo
    fi

    # root
    if [ "$LUKS" ]; then
        luks_format || return 1
        ROOT_DEV=/dev/mapper/cryptroot
    else
        ROOT_DEV="${DEVP}3"
    fi
    info "Formatting $ROOT_DEV as root partition..."
    if [ -e "$ROOT_DEV" ]; then
        yes | mkfs.ext4 "$ROOT_DEV"
    else
        err "$ROOT_DEV not found"
        return 1
    fi || return 1
    echo

    # home (optional)
    if [ -e "${DEVP}4" ]; then
        info "Formatting ${DEVP}4 as home partition..."
        yes | mkfs.ext4 "${DEVP}4"
    fi || return 1
    echo
}

mountall() {
    info "Setting main mount point to $MP"
    mkdir -p "$MP"
    echo

    ROOT_DEV="${DEVP}3"
    [ "$LUKS" ] && ROOT_DEV=/dev/mapper/cryptroot

    # root
    info "Mounting $ROOT_DEV as root partition..."
    if [ -e "$ROOT_DEV" ]; then
        mount "$ROOT_DEV" "$MP" &&
            mkdir -p "$MP/boot" &&
            mkdir -p "$MP/home"
    else
        err "$ROOT_DEV not found"
        return 1
    fi || return 1
    echo

    # boot
    info "Mounting ${DEVP}1 as boot partition..."
    if [ -e "${DEVP}1" ]; then
        mount "${DEVP}1" "$MP/boot"
    else
        err "${DEVP}1 not found"
        return 1
    fi || return 1
    echo

    # home (optional)
    if [ -e "${DEVP}4" ]; then
        info "Mounting ${DEVP}4 as home partition..."
        mount "${DEVP}4" "$MP/home"
        echo
    fi || return 1

    # swap
    if [ "$SKIP_SWAP" != 1 ]; then
        info "Enabling ${DEVP}2 as swap..."
        if [ -e "${DEVP}2" ]; then
            swapon "${DEVP}2"
        else
            err "${DEVP}2 not found"
            return 1
        fi || return 1
        echo
    fi
}

profile_packages() {
    case "$PROFILE" in
        server)
            echo 'docker nginx certbot certbot-nginx php php-fpm mariadb goaccess fail2ban imagemagick php-imagick php-gd dua-cli nodejs wp-cli jq' ;;

        gnome)
            echo 'xorg gnome gnome-extra gdm' ;;

        xfce)
            echo 'xorg xfce4 xfce4-goodies lightdm lightdm-gtk-greeter' ;;

        cinnamon)
            echo 'xorg cinnamon lightdm lightdm-gtk-greeter gnome-console' ;;
    esac
}

base_packages() {
    pacs='base base-devel networkmanager grub efibootmgr dosfstools'
    pacs="$pacs arch-install-scripts sudo dialog tmux nano ufw openssh"
    pacs="$pacs rsync htop zip unzip cronie sl"
    echo "$pacs"
}

installarch() {
    pacs=$(base_packages)
    [ "$LUKS" ] && pacs="$pacs cryptsetup"

    info "Updating keyrings..."
    if is_parabola; then
        yes | pacman -Sy archlinux-keyring parabola-keyring
        pacs="$pacs linux-libre linux-libre-firmware"
    else
        yes | pacman -Sy archlinux-keyring
        pacs="$pacs linux linux-firmware"
    fi || return 1

    extra=$(profile_packages)
    [ -n "$extra" ] && pacs="$pacs $extra"

    info "Installing packages..."
    # shellcheck disable=SC2086
    pacstrap "$MP" $pacs
    echo
}

fstabstuff() {
    genfstab -U "$MP" >> "$MP/etc/fstab"
}

dochroot() {
    cp "$SELF" "$MP/usr/bin/$NAME"
    chmod +x "$MP/usr/bin/$NAME"
    arch-chroot "$MP" sh -c "$(vars --all); export SKIP_SWAP=$SKIP_SWAP; '$NAME' --eval inchroot"
}

inchroot() {
    if is_parabola; then
        info "Installing Parabola's freedom and privacy..."
        # Append [nonprism] only if not already present
        if ! grep -q '^\[nonprism\]' /etc/pacman.conf; then
            printf '\n[nonprism]\nInclude = /etc/pacman.d/mirrorlist\n' \
                   >> /etc/pacman.conf
        fi
        yes | pacman -Sy your-freedom your-privacy
    fi

    info "Adding user $USERNAME and setting password..."
    useradd -m -g wheel "$USERNAME" || return 1
    printf '%s\n%s\n' "$PASSWORD" "$PASSWORD" |
        passwd "$USERNAME" || return 1
    echo

    info 'Setting root password...'
    printf '%s\n%s\n' "$PASSWORD" "$PASSWORD" |
        passwd || return 1
    echo

    info "Setting hostname to $HOSTNAME..."
    echo "$HOSTNAME" > /etc/hostname
    echo

    info "Setting timezone to $ZONE..."
    ln -sf "/usr/share/zoneinfo/$ZONE" /etc/localtime
    echo

    info 'Setting locale...'
    echo 'LANG=en-US.UTF-8' > /etc/locale.conf
    echo "LC_ALL=en_US.UTF-8" >> /etc/environment
    echo "$LOCALES" | tr ':' '\n' | while read -r l; do
        uncomment "$l" /etc/locale.gen
        info "Enabled $l"
    done
    locale-gen || return 1
    echo

    info 'Enabling network manager...'
    systemctl enable NetworkManager
    echo

    # GRUB — install for both UEFI and legacy BIOS.
    # The two grub-install calls are independent; if one target is not
    # supported by the firmware it will fail but we continue with the other.
    # grub-mkconfig runs once after both installs so it sees both entries.
    info 'Installing GRUB (UEFI)...'
    if [ -d /sys/firmware/efi ] || ls /boot/EFI 2>/dev/null | grep -qi efi; then
        mkdir -p /boot/EFI/GRUB
        grub-install --target=x86_64-efi --efi-directory=/boot \
            --bootloader-id=GRUB --recheck "$DEV" || \
            info 'UEFI GRUB install failed (non-fatal, may not be UEFI)'
    else
        info 'No EFI firmware detected, skipping UEFI GRUB install'
    fi

    info 'Installing GRUB (BIOS/legacy)...'
    grub-install --target=i386-pc --recheck "$DEV" || {
        err 'BIOS GRUB install failed'
        return 1
    }

    # LUKS: tell GRUB and mkinitcpio about the encrypted root
    if [ "$LUKS" ]; then
        root_uuid=$(blkid -s UUID -o value "${DEV}3" 2>/dev/null || \
                    blkid -s UUID -o value "${DEV}p3" 2>/dev/null)
        if [ "$root_uuid" ]; then
            sed -i "s|^GRUB_CMDLINE_LINUX=.*|GRUB_CMDLINE_LINUX=\"cryptdevice=UUID=${root_uuid}:cryptroot root=/dev/mapper/cryptroot\"|" \
                /etc/default/grub
        fi
        sed -i 's/^HOOKS=.*/HOOKS=(base udev autodetect modconf block encrypt filesystems keyboard fsck)/' \
            /etc/mkinitcpio.conf
        mkinitcpio -P || return 1
    fi

    info 'Disabling quiet mode...'
    sed -i \
        '/^GRUB_CMDLINE_LINUX_DEFAULT=/ s/[[:space:]]*quiet[[:space:]]*//g' \
        /etc/default/grub

    info 'Generating GRUB config...'
    grub-mkconfig -o /boot/grub/grub.cfg || return 1
    echo

    info 'Enabling wheel group in sudoers...'
    uncomment '%wheel ALL=(ALL:ALL) ALL' /etc/sudoers

    # Profile-specific post-install steps
    case "$PROFILE" in
        gnome)
            info 'Enabling GDM...'
            systemctl enable gdm ;;

        xfce|cinnamon)
            info 'Enabling LightDM...'
            systemctl enable lightdm ;;

        dots-base|dots-gui)
            info 'Installing dots...'
            curl https://raw.githubusercontent.com/Naheel-Azawy/nd/master/install.sh > /tmp/nd.sh
            sh /tmp/nd.sh "$USERNAME" ;;

        server)
            info 'Enabling Docker...'
            systemctl enable docker 2>/dev/null || true ;;
    esac

    info 'Enabling UFW...'
    systemctl enable ufw 2>/dev/null || true

    info 'Configuring pacman...'
    for opt in 'ILoveCandy' \
                   'ParallelDownloads = 5' \
                   'Color' 'VerbosePkgLists'; do
        grep -qF "$opt" /etc/pacman.conf || \
            sed -i "/^\[options\]/a $opt" /etc/pacman.conf
    done

    info 'Exitting shell...'
    echo
}

unmountall() {
    info "Syncing..."
    sync
    info "Unmounting all..."
    umount -R "$MP"
    [ "$SKIP_SWAP" != 1 ] && swapoff "${DEVP}2" 2>/dev/null || true
    [ "$LUKS" ] && luks_close
    rmdir "$MP" 2>/dev/null || true
}

tui() {
    export NEWT_COLORS='root=,black'

    box() {
        whiptail "$@" 10 50 3>&1 1>&2 2>&3
    }

    inputbox() {
        whiptail --inputbox "$1" 10 50 "$2" 3>&1 1>&2 2>&3
    }

    passwordbox() {
        whiptail --passwordbox "$1" 10 50 3>&1 1>&2 2>&3
    }

    menubox() {
        eval "whiptail --menu '$1' 20 60 12 $2" \
             3>&1 1>&2 2>&3
    }

    yesno() {
        whiptail --yesno "$1" 14 50 3>&1 1>&2 2>&3
    }

    msgbox() {
        whiptail --msgbox "$1" 14 50 3>&1 1>&2 2>&3
    }

    msgbox 'Welcome to Arch/Parabola installer script'

    DEV=
    devs=$(lsblk -rpno name,type | tac |
               awk '$2 == "disk" {printf "\"%s\" \"\" ", $1}')
    DEV=$(menubox 'Select a device:' "$devs")
    [ -z "$DEV" ] && return 1

    MP=$(inputbox 'Mount point:' "$MP")
    [ -z "$MP" ] && return 1

    USERNAME=
    USERNAME=$(inputbox 'Username:')
    [ -z "$USERNAME" ] && return 1

    PASSWORD=
    while :; do
        pass1=$(passwordbox 'Password:')
        pass2=$(passwordbox 'Re-enter password:')

        if [ -z "$pass1" ]; then
            msgbox 'Enter a non-empty password'
        elif [ "$pass1" != "$pass2" ]; then
            msgbox 'Passwords do not match. Try again...'
        else
            break
        fi
    done
    PASSWORD="$pass1"

    HOSTNAME=
    HOSTNAME=$(inputbox 'Host name:')
    [ -z "$HOSTNAME" ] && return 1

    zone_dir=
    dirs=$(ls -l --color=never /usr/share/zoneinfo/)
    dirs=$(echo "$dirs" | grep '^d' | awk '{printf "\"%s\" \"\" ", $NF}')
    msg='Set timezone'
    zone_dir=$(menubox "$msg" "$dirs")
    [ -z "$zone_dir" ] && return 1

    ZONE=
    zones=$(ls -1 --color=never "/usr/share/zoneinfo/$zone_dir")
    zones=$(echo "$zones" | awk '{printf "\"%s\" \"\" ", $NF}')
    ZONE=$(menubox "$msg" "$zones")
    ZONE="$zone_dir/$ZONE"
    [ -z "$ZONE" ] && return 1

    # LUKS encryption
    LUKS=
    if yesno 'Enable LUKS encryption on root partition?'; then
        LUKS=1
        LUKS_PASS=
        while :; do
            lp1=$(passwordbox 'LUKS passphrase (blank = use login password):')
            if [ -z "$lp1" ]; then
                LUKS_PASS="$PASSWORD"
                break
            fi
            lp2=$(passwordbox 'Re-enter LUKS passphrase:')
            if [ "$lp1" != "$lp2" ]; then
                msgbox 'Passphrases do not match. Try again...'
            else
                LUKS_PASS="$lp1"
                break
            fi
        done
    fi

    # Profile / desktop environment
    PROFILE=$(menubox 'Select install profile:' \
        '"minimal"   "Minimal" \
         "server"    "Server" \
         "gnome"     "GNOME + GDM" \
         "xfce"      "XFCE + LightDM" \
         "cinnamon"  "Cinnamon + LightDM" \
         "dots-gui"  "Naheel'\''s dotfiles (base + base-gui)" \
         "dots-base" "Naheel'\''s dotfiles (base)"')
    [ -z "$PROFILE" ] && return 1

    # GPT detection
    # if is_gpt "$DEV"; then
    #     if yesno "Disk $DEV has a GPT partition table. Convert to MBR? (default: No)"; then
    #         convert_gpt_to_mbr || { err 'GPT to MBR conversion failed'; return 1; }
    #     fi
    # fi

    # Auto partitioning
    AUTO_PART=$(menubox 'Partitioning:' \
        '"manual" "Partition manually with cfdisk" \
         "tiny"   "Auto: no swap, single partition (<8G disk)" \
         "mini"   "Auto: no swap, boot+root (~8G disk)" \
         "normal" "Auto: boot+swap(2xRAM)+root"')
    [ -z "$AUTO_PART" ] && return 1
    [ "$AUTO_PART" = manual ] && AUTO_PART=

    return 0
}

unattended() {
    # Source a vars file if provided
    if [ -n "$1" ] && [ -f "$1" ]; then
        info "Loading vars from $1"
        # shellcheck disable=SC1090
        . "$1"
    fi
    # All vars already have defaults at the top of the script;
    # nothing else needed.
}

main() {
    [ "$1" = --eval ] && {
        shift
        "$@"
        return
    }

    # Unattended mode: ./install-arch --unattended [vars-file]
    if [ "$1" = --unattended ] || [ "$UNATTENDED" = 1 ]; then
        UNATTENDED=1
        shift 2>/dev/null || true
        unattended "$1"
    fi

    check_root

    command -v pacstrap >/dev/null || {
        info 'Installing Arch install scripts'
        pacman -S arch-install-scripts
    }

    if [ "$UNATTENDED" != 1 ]; then
        tui  || return 1
        vars || return 1
    else
        info "Running unattended installation"
        vars
    fi
    echo

    printf "${E}WARNING:${R} everything under %s will be erased\n" "$DEV"
    if [ "$UNATTENDED" != 1 ]; then
        printf 'Are you sure? (y/N) '
        read -r ans
        case "$ans" in
            y|Y) ;;
            *)   return 0 ;;
        esac
    fi
    echo

    case "$DEV" in
        /dev/mmcblk*|/dev/nvme*)
            DEVP="${DEV}p" ;;
        *)
            DEVP="$DEV" ;;
    esac

    # Partitioning
    if [ "$AUTO_PART" ]; then
        autopart || return 1
    else
        echo 'Partition your disk as follows:'
        echo "- ${DEVP}1: boot"
        echo "- ${DEVP}2: swap"
        echo "- ${DEVP}3: root"
        echo "- ${DEVP}4: home (optional)"
        if [ "$UNATTENDED" != 1 ]; then
            echo 'Press enter to proceed'
            read -r _
            echo
            cfdisk "$DEV"
            echo
        fi
    fi
    sleep 3

    if [ -e "$DEV" ] &&
           [ -e "${DEVP}1" ] &&
           [ -e "${DEVP}3" ]; then
        info 'Partitions seem to be ok'
    else
        err 'bad partitioning'
        ls "${DEVP}1" 2>/dev/null
        ls "${DEVP}3" 2>/dev/null
        return 1
    fi
    echo

    if [ "$UNATTENDED" != 1 ]; then
        info 'Installation will start now'
        echo 'Press enter to proceed'
        read -r _
        echo
    fi

    start=$(date) &&
        mkfss &&
        mountall &&
        installarch &&
        fstabstuff &&
        dochroot
    status=$?

    end=$(date)
    printf '\033[1m\033[34mSTARTED AT\033[0m  %s\n' "$start"
    printf '\033[1m\033[34mFINISHED AT\033[0m %s\n' "$end"

    unmountall

    [ $status = 0 ] || err 'Installation failed :('

}

main "$@"
